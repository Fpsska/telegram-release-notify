BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_telegram_chat_id
JIRA_HOST=jira.yourcompany.com
JIRA_USERNAME=your_jira_username
JIRA_PASSWORD=your_jira_password
JIRA_QA_TESTERS=username1,username2,username3
JIRA_QA_LEAD=qa_lead_username
# Optional: SOCKS5/HTTP proxy for Telegram API access
# Formats: socks5://user:pass@host:port, socks5://host:port, http://user:pass@host:port
TELEGRAM_PROXY=socks5://user:password@your_vps_ip:1080
# Optional: GitLab access — enables --tag (CLI) / "Из GitLab по тегу" (UI) mode
GITLAB_HOST=gitlab.yourcompany.com
GITLAB_TOKEN=your_gitlab_token
GITLAB_PROJECT=group/repo
